<Window x:Class="CarDealership.Views.Dialogs.SaleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая продажа" Width="560" Height="500" MinWidth="480" MinHeight="420"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BackgroundDarkBrush}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Оформить продажу" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,25"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Автомобиль *" Style="{DynamicResource FormLabel}"/>
                    <ComboBox x:Name="CmbCar" Style="{DynamicResource ModernComboBox}"
                              DisplayMemberPath="DisplayName" SelectionChanged="CmbCar_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Margin="0,0,0,15">
                    <TextBlock Text="Клиент *" Style="{DynamicResource FormLabel}"/>
                    <ComboBox x:Name="CmbCustomer" Style="{DynamicResource ModernComboBox}"
                              DisplayMemberPath="FullName"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" Margin="0,0,0,15">
                    <TextBlock Text="Менеджер" Style="{DynamicResource FormLabel}"/>
                    <ComboBox x:Name="CmbManager" Style="{DynamicResource ModernComboBox}"
                              DisplayMemberPath="FullName"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="3" Margin="0,0,0,15">
                    <TextBlock Text="Цена продажи (₽) *" Style="{DynamicResource FormLabel}"/>
                    <TextBox x:Name="TxtPrice" Style="{DynamicResource ModernTextBox}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Grid.Row="3" Margin="0,0,0,15">
                    <TextBlock Text="Скидка (₽)" Style="{DynamicResource FormLabel}"/>
                    <TextBox x:Name="TxtDiscount" Text="0" Style="{DynamicResource ModernTextBox}"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="4" Margin="0,0,0,15">
                    <TextBlock Text="Способ оплаты" Style="{DynamicResource FormLabel}"/>
                    <ComboBox x:Name="CmbPayment" Style="{DynamicResource ModernComboBox}">
                        <ComboBoxItem Content="Наличные" IsSelected="True"/>
                        <ComboBoxItem Content="Кредит"/>
                        <ComboBoxItem Content="Лизинг"/>
                        <ComboBoxItem Content="Безнал"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Grid.Row="4" Margin="0,0,0,15">
                    <TextBlock Text="Статус" Style="{DynamicResource FormLabel}"/>
                    <ComboBox x:Name="CmbStatus" Style="{DynamicResource ModernComboBox}">
                        <ComboBoxItem Content="Completed" IsSelected="True"/>
                        <ComboBoxItem Content="Pending"/>
                        <ComboBoxItem Content="Cancelled"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="5" Margin="0,0,0,15">
                    <TextBlock Text="Заметки" Style="{DynamicResource FormLabel}"/>
                    <TextBox x:Name="TxtNotes" Style="{DynamicResource ModernTextBox}"
                             Height="55" TextWrapping="Wrap" AcceptsReturn="True"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Отмена" Padding="20,10" Margin="0,0,10,0"
                    Click="BtnCancel_Click" Background="{DynamicResource BackgroundCardBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Оформить продажу" Padding="25,10"
                    Style="{DynamicResource SuccessButton}" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
