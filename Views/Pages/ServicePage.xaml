<Page x:Class="CarDealership.Views.Pages.ServicePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundDarkBrush}">

    <Grid Margin="30,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Сервис" FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock x:Name="TxtCount" FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="+ Новая заявка"
                    Style="{DynamicResource PrimaryButton}" Click="BtnAdd_Click"/>
        </Grid>

        <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSearch" Style="{DynamicResource ModernTextBox}"
                         TextChanged="TxtSearch_TextChanged"/>
                <ComboBox Grid.Column="2" x:Name="CmbStatus" Style="{DynamicResource ModernComboBox}"
                          Width="180" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                    <ComboBoxItem Content="In Progress"/>
                    <ComboBoxItem Content="Completed"/>
                    <ComboBoxItem Content="Cancelled"/>
                </ComboBox>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{DynamicResource CardBorder}">
            <DataGrid x:Name="GridService" Style="{DynamicResource ModernDataGrid}"
                      MouseDoubleClick="GridService_MouseDoubleClick"
                      CanUserResizeColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45" MinWidth="40"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding ServiceDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="95" MinWidth="85"/>
                    <DataGridTextColumn Header="Автомобиль" Binding="{Binding CarName}" Width="2*" MinWidth="120"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding CustomerName}" Width="*" MinWidth="100"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding ServiceType}" Width="*" MinWidth="80"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*" MinWidth="120"/>
                    <DataGridTextColumn Header="Техник" Binding="{Binding TechnicianName}" Width="*" MinWidth="90"/>
                    <DataGridTextColumn Header="Стоимость" Binding="{Binding Cost, StringFormat=\{0:N0\} ₽}" Width="*" MinWidth="90"/>
                    <DataGridTemplateColumn Header="Статус" Width="110" MinWidth="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="In Progress">
                                                    <Setter Property="Background" Value="{DynamicResource BadgeOrangeBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                    <Setter Property="Background" Value="{DynamicResource BadgeGreenBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                    <Setter Property="Background" Value="{DynamicResource BadgeRedBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="In Progress">
                                                        <Setter Property="Text" Value="В работе"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Text" Value="Завершено"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                        <Setter Property="Text" Value="Отменено"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Действия" Width="105" MinWidth="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Удалить" Padding="8,4" FontSize="11"
                                        Style="{DynamicResource DangerButton}" Margin="0,4"
                                        Tag="{Binding Id}" Click="BtnDelete_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
