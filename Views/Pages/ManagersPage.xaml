<Page x:Class="CarDealership.Views.Pages.ManagersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundDarkBrush}">

    <Grid Margin="30,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Менеджеры" FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock x:Name="TxtCount" FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="+ Добавить менеджера"
                    Style="{DynamicResource PrimaryButton}" Click="BtnAdd_Click"/>
        </Grid>

        <Border Grid.Row="1" Style="{DynamicResource CardBorder}">
            <DataGrid x:Name="GridManagers" Style="{DynamicResource ModernDataGrid}"
                      MouseDoubleClick="GridManagers_MouseDoubleClick"
                      CanUserResizeColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45" MinWidth="40"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*" MinWidth="140"/>
                    <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="2*" MinWidth="120"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*" MinWidth="110"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" MinWidth="130"/>
                    <DataGridTextColumn Header="Дата найма" Binding="{Binding HireDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="105" MinWidth="95"/>
                    <DataGridTextColumn Header="Продаж" Binding="{Binding SalesCount}" Width="70" MinWidth="60"/>
                    <DataGridTemplateColumn Header="Статус" Width="95" MinWidth="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BadgeGreenBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Background" Value="{DynamicResource BadgeRedBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Text" Value="Активен"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Text" Value="Уволен"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Действия" Width="145" MinWidth="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Button Content="Ред." Padding="8,4" FontSize="11"
                                            Style="{DynamicResource PrimaryButton}" Margin="0,0,5,0"
                                            Tag="{Binding Id}" Click="BtnEdit_Click"/>
                                    <Button Content="Удал." Padding="8,4" FontSize="11"
                                            Style="{DynamicResource DangerButton}"
                                            Tag="{Binding Id}" Click="BtnDelete_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
