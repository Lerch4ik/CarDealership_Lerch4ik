<Page x:Class="CarDealership.Views.Pages.CustomersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundDarkBrush}">

    <Grid Margin="30,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Клиенты" FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock x:Name="TxtCount" FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="+ Добавить клиента"
                    Style="{DynamicResource PrimaryButton}" Click="BtnAdd_Click"/>
        </Grid>

        <!-- Search -->
        <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtSearch"
                         Style="{DynamicResource ModernTextBox}"
                         TextChanged="TxtSearch_TextChanged"/>
                <Button Grid.Column="2" Content="Сбросить" Padding="15,8"
                        Style="{DynamicResource PrimaryButton}" Click="BtnReset_Click"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Style="{DynamicResource CardBorder}">
            <DataGrid x:Name="GridCustomers" Style="{DynamicResource ModernDataGrid}"
                      MouseDoubleClick="GridCustomers_MouseDoubleClick"
                      CanUserResizeColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45" MinWidth="40"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*" MinWidth="150"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*" MinWidth="110"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" MinWidth="130"/>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="2*" MinWidth="120"/>
                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding DateOfBirth, StringFormat=\{0:dd.MM.yyyy\}}" Width="115" MinWidth="100"/>
                    <DataGridTextColumn Header="Добавлен" Binding="{Binding DateAdded, StringFormat=\{0:dd.MM.yyyy\}}" Width="100" MinWidth="90"/>
                    <DataGridTemplateColumn Header="Действия" Width="145" MinWidth="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Button Content="Ред." Padding="8,4" FontSize="11"
                                            Style="{DynamicResource PrimaryButton}" Margin="0,0,5,0"
                                            Tag="{Binding Id}" Click="BtnEdit_Click"/>
                                    <Button Content="Удал." Padding="8,4" FontSize="11"
                                            Style="{DynamicResource DangerButton}"
                                            Tag="{Binding Id}" Click="BtnDelete_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
