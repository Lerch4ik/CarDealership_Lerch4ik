<Page x:Class="CarDealership.Views.Pages.CarsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundDarkBrush}">

    <Grid Margin="30,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Автомобили" FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock x:Name="TxtCarCount" FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="+ Добавить автомобиль"
                    Style="{DynamicResource PrimaryButton}" Click="BtnAddCar_Click"/>
        </Grid>

        <!-- Search & Filters -->
        <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" x:Name="TxtSearch" 
                         Style="{DynamicResource ModernTextBox}"
                         Tag="Поиск по марке, модели, VIN..."
                         TextChanged="TxtSearch_TextChanged"/>

                <ComboBox Grid.Column="2" x:Name="CmbStatus"
                          Style="{DynamicResource ModernComboBox}"
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                    <ComboBoxItem Content="Available"/>
                    <ComboBoxItem Content="Reserved"/>
                    <ComboBoxItem Content="Sold"/>
                </ComboBox>

                <ComboBox Grid.Column="4" x:Name="CmbFuelType"
                          Style="{DynamicResource ModernComboBox}"
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все типы топлива" IsSelected="True"/>
                    <ComboBoxItem Content="Бензин"/>
                    <ComboBoxItem Content="Дизель"/>
                    <ComboBoxItem Content="Гибрид"/>
                    <ComboBoxItem Content="Электро"/>
                </ComboBox>

                <ComboBox Grid.Column="6" x:Name="CmbSort"
                          Style="{DynamicResource ModernComboBox}"
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="По ID ↑" IsSelected="True"/>
                    <ComboBoxItem Content="По цене ↓"/>
                    <ComboBoxItem Content="По цене ↑"/>
                    <ComboBoxItem Content="По году ↓"/>
                    <ComboBoxItem Content="По марке"/>
                </ComboBox>

                <Button Grid.Column="8" Content="Сбросить" Padding="15,8" 
                        Style="{DynamicResource PrimaryButton}" Click="BtnReset_Click"/>
            </Grid>
        </Border>

        <!-- Cars DataGrid -->
        <Border Grid.Row="2" Style="{DynamicResource CardBorder}">
            <DataGrid x:Name="GridCars" Style="{DynamicResource ModernDataGrid}"
                      SelectionChanged="GridCars_SelectionChanged"
                      MouseDoubleClick="GridCars_MouseDoubleClick"
                      CanUserResizeColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45" MinWidth="40"/>
                    <DataGridTextColumn Header="Марка" Binding="{Binding Brand}" Width="*" MinWidth="80"/>
                    <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="*" MinWidth="90"/>
                    <DataGridTextColumn Header="Год" Binding="{Binding Year}" Width="55" MinWidth="50"/>
                    <DataGridTextColumn Header="Цвет" Binding="{Binding Color}" Width="*" MinWidth="70"/>
                    <DataGridTextColumn Header="Кузов" Binding="{Binding BodyType}" Width="*" MinWidth="80"/>
                    <DataGridTextColumn Header="Топливо" Binding="{Binding FuelType}" Width="*" MinWidth="70"/>
                    <DataGridTextColumn Header="КПП" Binding="{Binding Transmission}" Width="*" MinWidth="70"/>
                    <DataGridTextColumn Header="Объём" Binding="{Binding EngineVolume}" Width="60" MinWidth="55"/>
                    <DataGridTextColumn Header="Пробег, км" Binding="{Binding Mileage, StringFormat=N0}" Width="*" MinWidth="80"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=\{0:N0\} ₽}" Width="*" MinWidth="100"/>
                    <DataGridTemplateColumn Header="Статус" Width="110" MinWidth="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Available">
                                                    <Setter Property="Background" Value="{DynamicResource BadgeGreenBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Reserved">
                                                    <Setter Property="Background" Value="{DynamicResource BadgeOrangeBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Sold">
                                                    <Setter Property="Background" Value="{DynamicResource BadgeBlueBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Available">
                                                        <Setter Property="Text" Value="Доступен"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Reserved">
                                                        <Setter Property="Text" Value="Резерв"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Sold">
                                                        <Setter Property="Text" Value="Продан"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Действия" Width="145" MinWidth="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Button Content="Ред." Padding="8,4" FontSize="11"
                                            Style="{DynamicResource PrimaryButton}" Margin="0,0,5,0"
                                            Tag="{Binding Id}"
                                            Click="BtnEditCar_Click"/>
                                    <Button Content="Удал." Padding="8,4" FontSize="11"
                                            Style="{DynamicResource DangerButton}"
                                            Tag="{Binding Id}"
                                            Click="BtnDeleteCar_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
