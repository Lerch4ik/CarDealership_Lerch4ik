<Window x:Class="CarDealership.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoPremium — Система управления автосалоном"
        Height="820" Width="1400"
        MinHeight="700" MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundDarkBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarGradient}">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="20,25,20,15"
                        BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="AutoPremium" FontSize="20" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Система управления" FontSize="11"
                                   Foreground="#88FFFFFF" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="12,15,12,0">
                    <TextBlock Text="НАВИГАЦИЯ" FontSize="10" FontWeight="Bold"
                               Foreground="#66FFFFFF" Margin="5,0,0,8"/>

                    <Button x:Name="BtnDashboard" Style="{DynamicResource NavButtonActive}"
                            Click="BtnDashboard_Click" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Дашборд" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnCars" Style="{DynamicResource NavButton}"
                            Click="BtnCars_Click" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚘" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Автомобили" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnCustomers" Style="{DynamicResource NavButton}"
                            Click="BtnCustomers_Click" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Клиенты" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnSales" Style="{DynamicResource NavButton}"
                            Click="BtnSales_Click" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Продажи" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnManagers" Style="{DynamicResource NavButton}"
                            Click="BtnManagers_Click" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👔" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Менеджеры" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnService" Style="{DynamicResource NavButton}"
                            Click="BtnService_Click" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔧" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Сервис" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="АНАЛИТИКА" FontSize="10" FontWeight="Bold"
                               Foreground="#66FFFFFF" Margin="5,20,0,8"/>

                    <Button x:Name="BtnReports" Style="{DynamicResource NavButton}"
                            Click="BtnReports_Click" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Отчёты" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Bottom: theme toggle + date -->
                <Border DockPanel.Dock="Bottom" Padding="12,12"
                        BorderBrush="#33FFFFFF" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <!-- Theme toggle button -->
                        <Button x:Name="BtnTheme" Click="BtnTheme_Click"
                                Cursor="Hand" Margin="0,0,0,12"
                                Background="#22FFFFFF" BorderThickness="0"
                                Padding="12,9">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <!-- Toggle pill -->
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="TxtThemeIcon" Grid.Column="0"
                                                       Text="☀️" FontSize="15"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="TxtThemeLabel" Grid.Column="1"
                                                       Text="Светлая тема" FontSize="12"
                                                       Foreground="White" VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                            <!-- Pill switch -->
                                            <Border Grid.Column="2" Width="36" Height="20"
                                                    CornerRadius="10" Margin="8,0,0,0"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush x:Name="PillBg" Color="#44FFFFFF"/>
                                                </Border.Background>
                                                <Ellipse x:Name="PillDot" Width="14" Height="14"
                                                         Fill="White" HorizontalAlignment="Right"
                                                         Margin="0,0,3,0"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Text="📅 AutoPremium CRM" FontSize="11" Foreground="#66FFFFFF"/>
                        <TextBlock x:Name="TxtCurrentDate" FontSize="11"
                                   Foreground="#66FFFFFF" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Border Grid.Column="1" Background="{DynamicResource BackgroundDarkBrush}">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>
