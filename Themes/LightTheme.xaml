<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Colors -->
    <Color x:Key="PrimaryColor">#F0F4FF</Color>
    <Color x:Key="SecondaryColor">#E8EEFF</Color>
    <Color x:Key="AccentColor">#2563EB</Color>
    <Color x:Key="AccentHoverColor">#1D4ED8</Color>
    <Color x:Key="AccentGreen">#16A34A</Color>
    <Color x:Key="AccentOrange">#D97706</Color>
    <Color x:Key="AccentRed">#DC2626</Color>
    <Color x:Key="AccentPurple">#7C3AED</Color>

    <!-- Background Colors -->
    <Color x:Key="BackgroundDark">#EEF2FF</Color>
    <Color x:Key="BackgroundMedium">#F0F4FF</Color>
    <Color x:Key="BackgroundLight">#F8FAFF</Color>
    <Color x:Key="BackgroundCard">#FFFFFF</Color>
    <Color x:Key="BackgroundHover">#E2E8FF</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#111827</Color>
    <Color x:Key="TextSecondary">#4B5563</Color>
    <Color x:Key="TextMuted">#9CA3AF</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderColor">#D1D9F0</Color>
    <Color x:Key="BorderColorLight">#BCC7E8</Color>

    <!-- Sidebar -->
    <Color x:Key="SidebarStart">#1E3A8A</Color>
    <Color x:Key="SidebarEnd">#1D4ED8</Color>

    <!-- DataGrid -->
    <Color x:Key="GridAltRow">#F5F8FF</Color>
    <Color x:Key="GridSelectedRow">#DBEAFE</Color>

    <!-- Status badge backgrounds -->
    <Color x:Key="BadgeGreen">#DCFCE7</Color>
    <Color x:Key="BadgeOrange">#FEF3C7</Color>
    <Color x:Key="BadgeBlue">#DBEAFE</Color>
    <Color x:Key="BadgeRed">#FEE2E2</Color>

    <!-- KPI cards -->
    <Color x:Key="KpiBlueStart">#1E3A8A</Color>
    <Color x:Key="KpiBlueEnd">#2563EB</Color>
    <Color x:Key="KpiGreenStart">#14532D</Color>
    <Color x:Key="KpiGreenEnd">#16A34A</Color>
    <Color x:Key="KpiOrangeStart">#92400E</Color>
    <Color x:Key="KpiOrangeEnd">#D97706</Color>
    <Color x:Key="KpiPurpleStart">#4C1D95</Color>
    <Color x:Key="KpiPurpleEnd">#7C3AED</Color>

    <!-- Fleet status -->
    <Color x:Key="FleetGreenBg">#F0FDF4</Color>
    <Color x:Key="FleetOrangeBg">#FFFBEB</Color>
    <Color x:Key="FleetBlueBg">#EFF6FF</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrange}"/>
    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}"/>
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}"/>

    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource BackgroundDark}"/>
    <SolidColorBrush x:Key="BackgroundMediumBrush" Color="{StaticResource BackgroundMedium}"/>
    <SolidColorBrush x:Key="BackgroundLightBrush" Color="{StaticResource BackgroundLight}"/>
    <SolidColorBrush x:Key="BackgroundCardBrush" Color="{StaticResource BackgroundCard}"/>
    <SolidColorBrush x:Key="BackgroundHoverBrush" Color="{StaticResource BackgroundHover}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>

    <SolidColorBrush x:Key="BorderBrush_" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderColorLight}"/>

    <SolidColorBrush x:Key="BadgeGreenBrush" Color="{StaticResource BadgeGreen}"/>
    <SolidColorBrush x:Key="BadgeOrangeBrush" Color="{StaticResource BadgeOrange}"/>
    <SolidColorBrush x:Key="BadgeBlueBrush" Color="{StaticResource BadgeBlue}"/>
    <SolidColorBrush x:Key="BadgeRedBrush" Color="{StaticResource BadgeRed}"/>
    <SolidColorBrush x:Key="FleetGreenBgBrush" Color="{StaticResource FleetGreenBg}"/>
    <SolidColorBrush x:Key="FleetOrangeBgBrush" Color="{StaticResource FleetOrangeBg}"/>
    <SolidColorBrush x:Key="FleetBlueBgBrush" Color="{StaticResource FleetBlueBg}"/>

    <!-- Gradients -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2563EB" Offset="0"/>
        <GradientStop Color="#7C3AED" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GreenGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#16A34A" Offset="0"/>
        <GradientStop Color="#15803D" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OrangeGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D97706" Offset="0"/>
        <GradientStop Color="#B45309" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="RedGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#DC2626" Offset="0"/>
        <GradientStop Color="#B91C1C" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource SidebarStart}" Offset="0"/>
        <GradientStop Color="{StaticResource SidebarEnd}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Theme meta -->
    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="ThemeName">Light</System:String>
    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="ThemeToggleIcon">🌙</System:String>
    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="ThemeToggleText">Тёмная тема</System:String>

</ResourceDictionary>
